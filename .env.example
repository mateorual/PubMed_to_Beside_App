# ── Required ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Recommended ───────────────────────────────────────────────────────────────
# Free at https://www.ncbi.nlm.nih.gov/account/ — increases PubMed rate limits
NCBI_API_KEY=
# Required by NCBI usage policy
NCBI_EMAIL=your.email@example.com

# ── Optional: open-source synthesis via Ollama ────────────────────────────────
# Run: ollama pull llama3.1:8b && ollama serve
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.1:8b
